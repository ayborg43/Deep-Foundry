# Dokploy Environment template.
# Paste these into the Dokploy service's "Environment" editor and fill in real
# values. Do NOT commit filled-in secrets. Compose reads them at deploy time.

# ── Public domain ────────────────────────────────────────────────────────────
# The domain you point at this stack (A/AAAA record → your Dokploy host).
# Used for Traefik routing, ALLOWED_HOSTS, CSRF/CORS, and absolute URLs.
# MUST be a bare hostname — no https://, no trailing slash, no path. It is
# interpolated into Traefik Host() rules and Django ALLOWED_HOSTS; a scheme or
# slash breaks routing and crash-loops the app on the corsheaders.E014 check.
DOMAIN=deepfoundry.example.com
# Traefik certificate resolver configured in your Dokploy install (default: letsencrypt).
CERT_RESOLVER=letsencrypt

# ── Django core (required) ───────────────────────────────────────────────────
APP_ENV=production
DJANGO_DEBUG=false
# python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=
# openssl rand -hex 32
INTERNAL_API_TOKEN=

# Optional overrides — sensible defaults are derived from DOMAIN if left unset:
# DJANGO_ALLOWED_HOSTS=deepfoundry.example.com
# CORS_ALLOWED_ORIGINS=https://deepfoundry.example.com
# CSRF_TRUSTED_ORIGINS=https://deepfoundry.example.com
# WEB_APP_URL=https://deepfoundry.example.com

# ── Database (required) ──────────────────────────────────────────────────────
DB_NAME=agentarium
DB_USER=agentarium
# openssl rand -base64 24
DB_PASSWORD=

# ── Object storage / MinIO (required) ────────────────────────────────────────
MINIO_ROOT_USER=agentarium
# openssl rand -base64 24
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=agentarium-knowledge

# ── Google sign-in (optional — button hides itself if blank) ─────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Email / SMTP (recommended for real sign-up & notifications) ──────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL defaults to "Deep-Foundry <noreply@$DOMAIN>" if unset.
# DEFAULT_FROM_EMAIL=Deep-Foundry <noreply@deepfoundry.example.com>

# ── Payments bridge (optional) ───────────────────────────────────────────────
PAYMENTS_CHECKOUT_BASE_URL=
PAYMENTS_WEBHOOK_SECRET=

# ── Built-in tools / sandbox (defaults are fine) ─────────────────────────────
# WEB_SEARCH_ENDPOINT=https://html.duckduckgo.com/html/
# SANDBOX_IMAGE=python:3.14-alpine
# SANDBOX_TIMEOUT_SECONDS=10
# SANDBOX_MEMORY_BYTES=134217728
# SANDBOX_NANO_CPUS=500000000
# SANDBOX_PIDS_LIMIT=64
