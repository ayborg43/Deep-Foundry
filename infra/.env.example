# Copy to .env in this directory and edit before running `docker compose up`.
# Never commit a real .env — see SECURITY.md §6.

APP_ENV=development
DJANGO_SECRET_KEY=dev-only-insecure-key-that-is-long-enough-for-local-jwt-signing
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Origin(s) of the web client — comma-separated for more than one.
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=cejGCUCoSNmRYVMLQQQX9KGwbOqCiauvwWsHIWy-RPY=

# Instance-wide DeepSeek key: set once and every workspace can run coworkers
# without its own key (a workspace key still overrides). Blank = per-workspace.
DEEPSEEK_API_KEY=

# Optional — leave blank to disable Google sign-in (the button hides itself).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Browser session inactivity timeout before returning to login.
SESSION_IDLE_TIMEOUT_MINUTES=30

# Built-in tools. Compose wires the private sandbox daemon URL internally.
WEB_SEARCH_ENDPOINT=https://html.duckduckgo.com/html/
WEB_SEARCH_TIMEOUT_SECONDS=10
# Free, keyless GDELT news discovery (blended into web search).
NEWS_SEARCH_ENABLED=true
NEWS_SEARCH_ENDPOINT=https://api.gdeltproject.org/api/v2/doc/doc
NEWS_SEARCH_TIMEOUT_SECONDS=15
NEWS_SEARCH_TIMESPAN=7d
NEWS_SEARCH_MIN_INTERVAL_SECONDS=5
NEWS_SEARCH_CACHE_SECONDS=900
WEB_READER_TIMEOUT_SECONDS=10
WEB_READER_MAX_RESPONSE_BYTES=2097152
WEB_READER_MAX_TEXT_CHARS=30000
WEB_READER_MAX_REDIRECTS=3
WEB_FETCH_TOTAL_TIMEOUT_SECONDS=30
WEB_DOCUMENT_MAX_RESPONSE_BYTES=26214400
CRAWLER_MAX_PAGES=50
CRAWLER_MAX_DEPTH=3
CRAWLER_MAX_DURATION_SECONDS=60
CRAWLER_PAGE_CACHE_SECONDS=3600
BROWSER_TIMEOUT_MS=20000
BROWSER_MAX_TEXT_CHARS=30000
BROWSER_MAX_HTML_CHARS=2000000
BROWSER_MAX_REQUESTS=100
BROWSER_MAX_TRANSFER_BYTES=26214400
SANDBOX_IMAGE=python:3.14-alpine
SANDBOX_TIMEOUT_SECONDS=10
SANDBOX_MEMORY_BYTES=134217728
SANDBOX_NANO_CPUS=500000000
SANDBOX_PIDS_LIMIT=64

DB_NAME=agentarium
DB_USER=agentarium
DB_PASSWORD=change-me
DB_PORT=5433

MINIO_ROOT_USER=agentarium
MINIO_ROOT_PASSWORD=change-me-too
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=agentarium-knowledge

# Console output is the safe local default. Use
# django.core.mail.backends.smtp.EmailBackend with real SMTP values in production.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
DEFAULT_FROM_EMAIL=Deep-Foundry <noreply@localhost>
WEB_APP_URL=http://localhost:3000
INTERNAL_API_TOKEN=change-me-to-a-long-random-internal-service-token

# Optional shared Telegram bot. Users connect through a one-time bot link;
# they never enter a phone number or chat ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# Phase 3 payment-provider bridge. The provider redirects buyers from the
# checkout URL and signs completion webhooks with this secret.
PAYMENTS_CHECKOUT_BASE_URL=
PAYMENTS_WEBHOOK_SECRET=change-me-to-a-long-random-payment-webhook-secret

GATEWAY_PORT=8080
APP_PORT=8000
WEB_PORT=3000
