# Copy to .env in this directory and edit before running `docker compose up`.
# Never commit a real .env — see SECURITY.md §6.

DJANGO_SECRET_KEY=change-me-to-a-random-value
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
# Origin(s) of the web client — comma-separated for more than one.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=change-me-to-a-generated-fernet-key

# Optional — leave blank to disable Google sign-in (the button hides itself).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

DB_NAME=agentarium
DB_USER=agentarium
DB_PASSWORD=change-me
DB_PORT=5433

MINIO_ROOT_USER=agentarium
MINIO_ROOT_PASSWORD=change-me-too
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

GATEWAY_PORT=8080
APP_PORT=8000
